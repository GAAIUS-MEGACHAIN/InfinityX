    "@capacitor/core": "^8.0.0",
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@metaplex-foundation/umi-web3js-adapters": "^1.5.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/spl-token-metadata": "^0.1.6",
    "@solana/web3.js": "^1.98.4",
    "@vitejs/plugin-react": "^6.0.2",
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "^7.1.0",
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@cityofzion/neon-js": "^5.9.0",
    "@cosmjs/amino": "^0.39.0",
    "@cosmjs/proto-signing": "^0.39.0",
    "@cosmjs/stargate": "^0.39.0",
    "@multiversx/sdk-core": "^15.4.1",
    "@mysten/sui": "^2.17.0",
    "@noble/hashes": "^2.2.0",
    "@polkadot/api": "^16.5.6",
    "@polkadot/keyring": "^14.0.3",
    "@polkadot/util-crypto": "^14.0.3",
    "@reown/walletkit": "^1.5.5",
    "@scure/base": "^2.2.0",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.4.0",
    "@stellar/stellar-sdk": "^15.1.0",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.2.4",
    "@walletconnect/core": "^2.23.9",
    "@walletconnect/utils": "^2.23.9",
    "algosdk": "^3.5.2",
    "bitcoinjs-lib": "^7.0.1",
    "buffer": "^6.0.3",
    "ecpair": "^3.0.1",
    "ed25519-hd-key": "^2.0.0",
    "tronweb": "^6.3.0",
    "tweetnacl": "^1.0.3",
    "viem": "^2.50.4",
    "xrpl": "^4.6.0"
  }
