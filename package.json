{
  "name": "infinityx",
  "version": "0.1.0",
  "description": "InfinityX mobile wallet and token launch workspace.",
  "type": "module",
  "private": true,
  "overrides": {
    "axios": "^1.16.1",
    "lodash": "^4.18.1",
    "uuid": "11.1.1",
    "ws": "^8.21.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "android:add": "npx cap add android",
    "android:sync": "npm.cmd run build && .\\node_modules\\.bin\\cap.cmd sync android",
    "apk": "npm.cmd run android:sync && cd android && .\\gradlew.bat assembleDebug",
    "preview": "vite preview --host 127.0.0.1",
    "backend": "python backend/infinityx_backend.py",
    "audit": "node scripts/audit-pack.mjs",
    "capability:scan": "node scripts/capability-scan.mjs",
    "registry:top3000": "node scripts/generate-top3000-registry.mjs",
    "registry:chains": "node scripts/sync-chain-registry.mjs",
    "update-packs": "node scripts/build-update-pack.mjs",
    "token:wallet": "node scripts/generate-solana-wallet.js",
    "token:airdrop:devnet": "node scripts/airdrop-devnet-sol.js",
    "token:create:devnet": "node scripts/create-infinityx-token.js --network devnet",
    "token:create:mainnet": "node scripts/create-infinityx-token.js --network mainnet-beta",
    "token:create:spl:devnet": "node scripts/create-infinityx-classic-spl-token.js --network devnet",
    "token:create:spl:mainnet": "node scripts/create-infinityx-classic-spl-token.js --network mainnet-beta",
    "token:swap-usdc-sol": "node scripts/swap-usdc-to-sol.js",
    "token:balance:devnet": "node scripts/check-solana-wallet.js --network devnet",
    "token:balance:mainnet": "node scripts/check-solana-wallet.js --network mainnet-beta"
  },
  "keywords": [
    "infinityx",
    "solana",
    "wallet"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
